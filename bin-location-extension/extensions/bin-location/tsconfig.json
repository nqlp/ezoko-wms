{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "target": "ES2020",
    "checkJs": true,
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "../../..",
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "../../../shared/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../../../shared/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}